# Netlify DB / Neon
NETLIFY_DATABASE_URL=

# Optional fallbacks
DATABASE_URL=
NETLIFY_DATABASE_URL_UNPOOLED=
POSTGRES_URL=

# Auth/session behavior
SESSION_TTL_HOURS=24
REMEMBER_TTL_DAYS=30
COOKIE_NAME=finance_session
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax

# Frontend URL used in password reset links
APP_FRONTEND_URL=

# Optional additional origins (comma-separated)
CORS_ALLOW_ORIGINS=

# Return reset URL in API response for debugging local/dev
ENABLE_DEBUG_RESET_URL=false
